# ── Google OAuth (로그인 + 회의 일정 캘린더) ──
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── NextAuth ──
# 랜덤 문자열 (openssl rand -base64 32)
AUTH_SECRET=your-auth-secret

# ── Supabase ──
# NEXT_PUBLIC_* 는 브라우저로 노출되어도 안전한 값.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# service_role 키는 서버 전용. 절대 브라우저로 노출하지 말 것.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Cron (선택) ──
# 설정 시 /api/followups/check-overdue 호출에 Authorization: Bearer <값> 검증.
# 미설정 시 검증 없이 통과 (Vercel Cron 기본 호출과 호환).
# CRON_SECRET=your-cron-secret
