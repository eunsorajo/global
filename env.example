# Claude API (Anthropic) — 회의록 자동 생성, 파트너 인사이트
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI Whisper — 음성 파일 → 텍스트 변환 (STT)
OPENAI_API_KEY=your-openai-api-key

# Google OAuth & APIs — 로그인, Calendar, Drive, Sheets
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Sheets ID — 파트너사 정보를 저장할 시트 ID (URL에서 확인)
GOOGLE_SHEETS_ID=your-spreadsheet-id

# Google Drive Folder ID — 회의록을 저장할 Drive 폴더 ID
GOOGLE_DRIVE_FOLDER_ID=your-folder-id

# NextAuth Secret — 랜덤 문자열 (openssl rand -base64 32)
AUTH_SECRET=your-auth-secret
